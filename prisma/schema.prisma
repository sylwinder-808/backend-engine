generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

enum Role {
SUPER_ADMIN
CLIENT_ADMIN
STAFF
PLAYER
}

enum DomainStatus {
ACTIVE
INACTIVE
MAINTENANCE
}

enum TransactionStatus {
PENDING
APPROVED
REJECTED
CANCELLED
}

model Tenant {
id        String   @id @default(cuid())
name      String
code      String   @unique
status    String   @default("ACTIVE")
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

users           User[]
domains         Domain[]
deposits        Deposit[]
withdrawals     Withdrawal[]
transactions    Transaction[]
siteSettings    SiteSetting[]
auditLogs       AuditLog[]
banners         Banner[]
paymentTargets  PaymentTarget[]
contactSetting  ContactSetting?
templateSetting TemplateSetting?
}

model Domain {
id        String       @id @default(cuid())
tenantId  String
host      String       @unique
status    DomainStatus @default(ACTIVE)
isPrimary Boolean      @default(false)
createdAt DateTime     @default(now())
updatedAt DateTime     @updatedAt

tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

@@index([tenantId])
}

model User {
id           Int      @id @default(autoincrement())

tenantId     String?
tenant       Tenant?  @relation(fields: [tenantId], references: [id])

username     String
email        String
phone        String
password     String

role         Role     @default(PLAYER)

isBlocked    Boolean  @default(false)
createdAt    DateTime @default(now())

adminLogs    AdminLog[]
bankAccount  BankAccount[]
deposits     Deposit[]
ledgers      Ledger[]
transactions Transaction[]
wallet       Wallet?
withdrawals  Withdrawal[]

@@unique([tenantId, username])
@@unique([tenantId, email])
@@index([tenantId])
}

model Wallet {
id          Int   @id @default(autoincrement())
userId      Int   @unique

balance     Float @default(0)
holdBalance Float @default(0)

user User @relation(fields: [userId], references: [id])

@@index([userId])
}

model BankAccount {
id            Int    @id @default(autoincrement())
userId        Int

bankName      String
accountName   String
accountNumber String
paymentMethod String?

user User @relation(fields: [userId], references: [id])

@@index([userId])
}

model Deposit {
  id        Int      @id @default(autoincrement())

  tenantId  String?
  userId    Int

  amount    Float

  method        String?
  originAccount String?

  targetBankId  Int?

  serialNumber  String?

  proofUrl      String?

  status    TransactionStatus @default(PENDING)

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
}

model Withdrawal {
id            Int      @id @default(autoincrement())

tenantId      String?
userId        Int

amount        Float

accountName   String
accountNumber String
bankName      String

beforeBalance Float
afterBalance  Float

status        TransactionStatus @default(PENDING)

createdAt     DateTime @default(now())

tenant Tenant? @relation(fields: [tenantId], references: [id])
user   User    @relation(fields: [userId], references: [id])

@@index([tenantId])
@@index([userId])
}

model Transaction {
id            Int      @id @default(autoincrement())

tenantId      String?
userId        Int

invoiceNo     String?  @unique

type          String
amount        Float

beforeBalance Float
afterBalance  Float

description   String

status        TransactionStatus @default(APPROVED)

createdAt     DateTime @default(now())

tenant Tenant? @relation(fields: [tenantId], references: [id])
user   User    @relation(fields: [userId], references: [id])

@@index([tenantId])
@@index([userId])
}

model Ledger {
id        Int      @id @default(autoincrement())

userId    Int

type      String
amount    Float
direction String

before    Float
after     Float

refId     Int?

createdAt DateTime @default(now())

user User @relation(fields: [userId], references: [id])

@@index([userId])
}

model AdminLog {
id        Int      @id @default(autoincrement())

adminId   Int
action    String

targetId  Int?
meta      Json?

createdAt DateTime @default(now())

admin User @relation(fields: [adminId], references: [id])
}

model AuditLog {
id        String   @id @default(cuid())

tenantId  String?
actorId   Int?

action    String
entity    String
entityId  String?

metadata  Json?

createdAt DateTime @default(now())

tenant Tenant? @relation(fields: [tenantId], references: [id])

@@index([tenantId])
@@index([actorId])
}

model SiteSetting {
id        String   @id @default(cuid())

tenantId  String

siteName  String

logoUrl   String?
faviconUrl String?

maintenanceMode Boolean @default(false)

createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

tenant Tenant @relation(fields: [tenantId], references: [id])

@@unique([tenantId])
}

model Banner {
  id          String   @id @default(cuid())

  tenantId    String

  title       String
  subtitle    String?

  placement   String

  href        String?

  imageUrl    String

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([placement])
  @@index([isActive])
}

model PaymentTarget {
  id            Int      @id @default(autoincrement())

  tenantId      String

  bankName      String
  accountName   String
  accountNumber String

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model ContactSetting {
  id String @id @default(cuid())

  tenantId String @unique

  whatsapp   String?
  telegram   String?
  email      String?
  livechatUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model TemplateSetting {
  id String @id @default(cuid())

  tenantId String @unique

  primaryColor   String?
  secondaryColor String?

  loginBackground    String?
  registerBackground String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}